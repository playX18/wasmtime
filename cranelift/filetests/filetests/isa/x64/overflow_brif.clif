;; Intervening same-block use of the sum prevents fusion: expect seto + test + jnz.
function %sadd_overflow_intervening(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2, v3 = sadd_overflow v0, v1
    v4 = iadd v2, v0
    brif v3, block1, block2

block1:
    return v4

block2:
    v5 = iconst.i32 0
    return v5
}

