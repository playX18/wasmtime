test compile precise-output
target x86_64

function %sadd_overflow_brif(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2, v3 = sadd_overflow v0, v1
    brif v3, block1, block2

block1:
    return v2

block2:
    v4 = iconst.i32 0
    return v4
}

